{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'none'; base-uri 'self'; object-src 'none'; upgrade-insecure-requests"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains; preload"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), interest-cohort=()"
        },
        {
          "key": "X-DNS-Prefetch-Control",
          "value": "off"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/guides/april-2026-guide",
      "destination": "/insights/salary-calculator-uk-2026",
      "statusCode": 301
    },
    {
      "source": "/guides/wfh-relief-gone",
      "destination": "/insights/working-from-home-tax-relief-uk",
      "statusCode": 301
    },
    {
      "source": "/guides/60-percent-tax-trap",
      "destination": "/insights/personal-allowance-taper-100k-trap",
      "statusCode": 301
    },
    {
      "source": "/guides/national-insurance-guide",
      "destination": "/insights/national-insurance-2026-explained",
      "statusCode": 301
    },
    {
      "source": "/guides/student-loan-guide",
      "destination": "/insights/student-loan-plan-5-calculator",
      "statusCode": 301
    },
    {
      "source": "/guides/:slug",
      "destination": "/insights/:slug",
      "statusCode": 301
    },
    {
      "source": "/guides",
      "destination": "/insights",
      "statusCode": 301
    },
    {
      "source": "/oxford-methodology",
      "destination": "/methodology",
      "statusCode": 301
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
